# Runtime database connection used by the app and Prisma Client.
DATABASE_URL="mysql://username:password@127.0.0.1:3306/networkconnectit_command_center"

# Local-only helper for `prisma migrate dev` when your normal app user cannot create a shadow DB.
DATABASE_ADMIN_URL="mysql://root:your-root-password@127.0.0.1:3306/networkconnectit_command_center"

# Root deployment example:
# NEXTAUTH_URL="http://localhost:3000"
# Reverse-proxied path deployment example:
# NEXTAUTH_URL="https://networkconnectit.com/tools/command-center/api/auth"
NEXTAUTH_URL="http://localhost:3000"

# Use a long random secret in staging and production.
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# One-time bootstrap route for creating the first non-demo internal admin.
# Keep disabled by default. Enable only long enough to create the first SUPER_ADMIN,
# then turn it off again immediately.
ENABLE_FIRST_ADMIN_BOOTSTRAP="false"
FIRST_ADMIN_BOOTSTRAP_TOKEN=""

# Leave blank for root deployments. Set to e.g. /tools/command-center when mounted behind a path proxy.
NEXT_PUBLIC_APP_BASE_PATH=""

# Optional but recommended so login-shell links can point back to the public marketing site.
NEXT_PUBLIC_MARKETING_SITE_URL=""
